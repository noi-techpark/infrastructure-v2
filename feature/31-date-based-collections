variable "ingestion_date" {
  description = "The ingestion date in YYYY-MM-DD format"
  type        = string
}

locals {
  # Extract date components
  year  = substr(var.ingestion_date, 0, 4)
  month = substr(var.ingestion_date, 5, 2)
  day   = substr(var.ingestion_date, 8, 2)

  # Dynamic collection name
  collection_name = "raw_data_${local.year}_${local.month}_${local.day}"

  # Optional structured path (data lake pattern)
  storage_path = "raw-data/year=${local.year}/month=${local.month}/day=${local.day}/"
}

resource "open_data_hub_collection" "raw_by_date" {
  name = local.collection_name

  metadata = {
    ingestion_date = var.ingestion_date
    year           = local.year
    month          = local.month
    day            = local.day
  }

  storage = {
    path = local.storage_path
    type = "raw"
  }
}
