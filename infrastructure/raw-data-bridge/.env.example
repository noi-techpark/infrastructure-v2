APP_MONGO_URI=mongodb://mongodb

# S3 / object storage — endpoint with scheme (http:// or https://)
# Leave empty to use AWS S3 (s3.amazonaws.com) over HTTPS.
APP_S3_ENDPOINT=http://minio:9000
APP_S3_ACCESS_KEY_ID=minioadmin
APP_S3_SECRET_ACCESS_KEY=minioadmin

APP_LOG_LEVEL=DEBUG

SERVICE_NAME=raw-fata-bridge
TELEMETRY_TRACE_GRPC_ENDPOINT=tempo-distributor-discovery.monitoring.svc.cluster.local:4317