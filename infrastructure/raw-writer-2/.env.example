# HTTP server
HTTP_PORT=8080

# MongoDB — service name matches docker-compose.yml
MONGO_URI=mongodb://mongodb:27017
DB_PREFIX=raw-

# S3 / object storage — MinIO service from docker-compose.yml
S3_BUCKET=raw-data
S3_REGION=eu-west-1
S3_ENDPOINT=http://minio:9000

# MinIO credentials (must match MINIO_ROOT_USER/PASSWORD in docker-compose.yml)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Maximum accepted body size in bytes (default 100 MB)
MAX_SIZE=104857600

# RabbitMQ — service name matches docker-compose.yml
MQ_URI=amqp://guest:guest@rabbitmq:5672/
MQ_CLIENT_NAME=raw-writer-2
MQ_READY_EXCHANGE=raw-exchange
MQ_READY_QUEUE=raw-ready
MQ_READY_DL_QUEUE=raw-ready-dl

# OpenTelemetry (via noi-techpark/opendatahub-go-sdk/tel)
SERVICE_NAME=raw-writer-2
SERVICE_VERSION=0.0.1
TELEMETRY_ENABLED=true
TELEMETRY_TRACE_ENABLED=true
TELEMETRY_TRACE_GRPC_ENDPOINT=localhost:4317
TELEMETRY_METRICS_ENABLED=false
